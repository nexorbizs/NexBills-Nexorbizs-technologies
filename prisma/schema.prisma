generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id           Int            @id @default(autoincrement())
  name         String
  email        String         @unique
  password     String
  createdAt    DateTime       @default(now())
  users        User[]
  products     Product[]
  customers    Customer[]
  sales        Sale[]
  setting      Setting?
  suppliers    Supplier[]
  purchases    Purchase[]
  subscription Subscription?
  branches     Branch[]
  activityLogs ActivityLog[]  // ⭐ NEW
}

model Branch {
  id           Int          @id @default(autoincrement())
  name         String
  address      String       @default("")
  phone        String       @default("")
  isActive     Boolean      @default(true)
  companyId    Int
  createdAt    DateTime     @default(now())
  company      Company      @relation(fields: [companyId], references: [id])
  sales        Sale[]
  purchases    Purchase[]
  customers    Customer[]
  users        UserBranch[]
  activityLogs ActivityLog[] // ⭐ NEW
}

model UserBranch {
  userId   Int
  branchId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

model Subscription {
  id          Int      @id @default(autoincrement())
  companyId   Int      @unique
  plan        String   @default("trial")
  status      String   @default("active")
  startDate   DateTime @default(now())
  expiryDate  DateTime
  maxUsers    Int      @default(1)
  maxBranches Int      @default(1)
  notes       String   @default("")
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  role         String        @default("OWNER")
  name         String        @default("")
  companyId    Int
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  company      Company       @relation(fields: [companyId], references: [id])
  branches     UserBranch[]
  activityLogs ActivityLog[] // ⭐ NEW
}

// ⭐ NEW - Activity Log model
model ActivityLog {
  id         Int      @id @default(autoincrement())
  companyId  Int
  userId     Int?
  branchId   Int?
  userName   String   @default("")
  branchName String   @default("")
  module     String   // "SALE" | "PRODUCT" | "CUSTOMER" | "PURCHASE"
  action     String   // "CREATED" | "UPDATED" | "DELETED"
  summary    String   // human readable: "Created invoice #INV001 for John - ₹500"
  details    String   @default("") // optional JSON or extra info
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
  branch     Branch?  @relation(fields: [branchId], references: [id])
}

model Setting {
  id        Int     @id @default(autoincrement())
  companyId Int     @unique
  shopName  String
  gstNumber String
  phone     String
  address   String
  company   Company @relation(fields: [companyId], references: [id])
}

model Product {
  id            Int            @id @default(autoincrement())
  name          String
  sku           String
  hsn           String
  price         Float
  stock         Int
  cgst          Float
  sgst          Float
  discount      Float          @default(0)
  barcode   String   @default("")
  companyId     Int
  createdAt     DateTime       @default(now())
  company       Company        @relation(fields: [companyId], references: [id])
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  address   String
  companyId Int
  branchId  Int?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
  branch    Branch?  @relation(fields: [branchId], references: [id])
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String
  address   String
  gstin     String     @default("")
  companyId Int
  createdAt DateTime   @default(now())
  company   Company    @relation(fields: [companyId], references: [id])
  purchases Purchase[]
}

model Purchase {
  id             Int            @id @default(autoincrement())
  purchaseNo     String
  supplierId     Int
  supplierName   String
  subTotal       Float
  discountAmount Float          @default(0)
  taxAmount      Float          @default(0)
  total          Float
  paymentMode    String         @default("cash")
  amountPaid     Float          @default(0)
  balance        Float          @default(0)
  notes          String         @default("")
  companyId      Int
  branchId       Int?
  createdAt      DateTime       @default(now())
  company        Company        @relation(fields: [companyId], references: [id])
  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  branch         Branch?        @relation(fields: [branchId], references: [id])
  items          PurchaseItem[]
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())
  purchaseId  Int
  productId   Int
  productName String
  hsn         String
  qty         Int
  price       Float
  cgst        Float    @default(0)
  sgst        Float    @default(0)
  total       Float
  purchase    Purchase @relation(fields: [purchaseId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model Sale {
  id             Int        @id @default(autoincrement())
  invoiceNo      String
  customerName   String
  customerPhone  String
  subTotal       Float
  discountType   String     @default("percent")
  discountValue  Float      @default(0)
  discountAmount Float      @default(0)
  roundOff       Float
  total          Float
  paymentMode    String
  amountReceived Float
  balance        Float
  companyId      Int
  branchId       Int?
  createdAt      DateTime   @default(now())
  company        Company    @relation(fields: [companyId], references: [id])
  branch         Branch?    @relation(fields: [branchId], references: [id])
  items          SaleItem[]
}

model SaleItem {
  id              Int     @id @default(autoincrement())
  saleId          Int
  productId       Int
  productName     String
  hsn             String
  price           Float
  qty             Int
  discount        Float   @default(0)
  discountedPrice Float   @default(0)
  cgst            Float
  sgst            Float
  total           Float
  sale            Sale    @relation(fields: [saleId], references: [id])
  product         Product @relation(fields: [productId], references: [id])
}